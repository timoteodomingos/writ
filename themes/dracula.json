{
  "name": "Dracula",
  "author": "Wilfred Denton",
  "url": "https://draculatheme.com",
  "$schema": "https://github.com/longbridge/gpui-component/raw/refs/heads/main/.theme-schema.json",
  "themes": [
    {
      "name": "Dracula",
      "mode": "dark",
      "colors": {
        "accent.background": "#44475A",
        "accent.foreground": "#F8F8F2",
        "background": "#282A36",
        "border": "#6272A4",
        "foreground": "#F8F8F2",
        "input.border": "#6272A4",
        "link.active.foreground": "#8BE9FD",
        "link.foreground": "#8BE9FD",
        "link.hover.foreground": "#8BE9FD",
        "list.active.background": "#44475A",
        "list.active.border": "#BD93F9",
        "list.even.background": "#21222C",
        "muted.background": "#6272A455",
        "muted.foreground": "#6272A4",
        "panel.background": "#21222C",
        "popover.background": "#343746",
        "popover.foreground": "#F8F8F2",
        "primary.background": "#BD93F9",
        "primary.foreground": "#282A36",
        "scrollbar.background": "#282A3600",
        "scrollbar.thumb.background": "#6272A4",
        "secondary.background": "#44475A",
        "secondary.active.background": "#6272A4",
        "secondary.foreground": "#F8F8F2",
        "secondary.hover.background": "#6272A4",
        "tab.active.background": "#282A36",
        "tab.foreground": "#6272A4",
        "title_bar.background": "#21222C",
        "title_bar.border": "#6272A4",
        "base.red": "#FF5555",
        "base.green": "#50FA7B",
        "base.blue": "#BD93F9",
        "base.cyan": "#8BE9FD",
        "base.magenta": "#FF79C6",
        "base.magenta.light": "#FF79C633",
        "base.yellow": "#F1FA8C"
      },
      "highlight": {
        "editor.foreground": "#F8F8F2",
        "editor.background": "#282A36",
        "editor.active_line.background": "#44475A",
        "editor.line_number": "#6272A4",
        "editor.active_line_number": "#F8F8F2",
        "conflict": "#FF5555",
        "created": "#50FA7B",
        "deleted": "#FF5555",
        "error": "#FF5555",
        "hidden": "#6272A4",
        "hint": "#8BE9FD",
        "ignored": "#6272A4",
        "info": "#8BE9FD",
        "modified": "#FFB86C",
        "predictive": "#44475A",
        "renamed": "#8BE9FD",
        "success": "#50FA7B",
        "unreachable": "#6272A4",
        "warning": "#FFB86C",
        "syntax": {
          "attribute": {
            "color": "#8BE9FD"
          },
          "boolean": {
            "color": "#FFB86C"
          },
          "comment": {
            "color": "#6272A4",
            "font_style": "italic"
          },
          "comment.doc": {
            "color": "#6272A4",
            "font_style": "italic"
          },
          "constant": {
            "color": "#FFB86C"
          },
          "constructor": {
            "color": "#BD93F9"
          },
          "embedded": {
            "color": "#F8F8F2"
          },
          "function": {
            "color": "#F1FA8C"
          },
          "keyword": {
            "color": "#FF79C6"
          },
          "link_text": {
            "color": "#8BE9FD",
            "font_style": "underline"
          },
          "link_uri": {
            "color": "#8BE9FD",
            "font_style": "italic"
          },
          "number": {
            "color": "#FFB86C"
          },
          "string": {
            "color": "#50FA7B"
          },
          "string.escape": {
            "color": "#FF79C6"
          },
          "string.regex": {
            "color": "#FF5555"
          },
          "string.special": {
            "color": "#FF79C6"
          },
          "string.special.symbol": {
            "color": "#FF79C6"
          },
          "tag": {
            "color": "#FF79C6"
          },
          "text.literal": {
            "color": "#F8F8F2"
          },
          "title": {
            "color": "#BD93F9",
            "font_weight": 600
          },
          "type": {
            "color": "#BD93F9"
          },
          "property": {
            "color": "#F8F8F2"
          },
          "variable.special": {
            "color": "#BD93F9"
          }
        }
      }
    }
  ]
}
